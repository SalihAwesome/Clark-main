# Copy this file to .env and fill in your real keys. .env is gitignored.
# FIREWORKS_API_KEY is required (primary); GEMINI_API_KEY is optional (fallback).

# Fireworks AI (primary LLM provider)
FIREWORKS_API_KEY=your_fireworks_api_key_here

# Google Gemini API (fallback — used when Fireworks is unreachable)
GEMINI_API_KEY=your_gemini_api_key_here

# Optional model overrides (defaults shown)
FIREWORKS_MODEL=accounts/fireworks/models/deepseek-v4-pro
FIREWORKS_VISION_MODEL=accounts/fireworks/models/kimi-k2p6
GEMINI_MODEL=gemma-4-26b-a4b-it

# LLM client settings
LLM_TIMEOUT=75              # per-call timeout in seconds (default 75)
LLM_FAST_TIMEOUT=15         # fast-path timeout in seconds (default 15)
LLM_DOWN_TTL=180            # seconds to mark a provider as down after a transient error (default 180)

# Agent runtime
AGENT_WORKSPACE=agent_workspace
BROWSER_HEADLESS=false
BROWSER_LOCALE=en-US        # browser UI language
BROWSER_FAST=false          # false = full load like a normal browser; true = skip images/media

# Anti-bot / reCAPTCHA (login on protected portals)
BROWSER_PERSISTENT=true     # reuse a saved Chrome profile across runs
BROWSER_PROFILE_DIR=        # optional: override profile directory path
BROWSER_CDP_AUTODETECT=true # auto-use a debuggable Chrome on port 9222
